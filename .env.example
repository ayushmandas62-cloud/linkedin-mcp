# ── LinkedIn OAuth App ──────────────────────────────────────────────────────
# Create an app at https://www.linkedin.com/developers/apps
# Required products: "Sign In with LinkedIn using OpenID Connect" + "Share on LinkedIn"
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# ── OAuth Redirect URI ──────────────────────────────────────────────────────
# Must match exactly what you set in LinkedIn App → Auth → Redirect URLs
# Local development:
LINKEDIN_REDIRECT_URI=http://localhost:3001/auth/callback
# Railway deployment (set automatically if RAILWAY_PUBLIC_DOMAIN is present):
# LINKEDIN_REDIRECT_URI=https://your-app.up.railway.app/auth/callback

# ── AI Post Generation (optional) ──────────────────────────────────────────
# Free key at https://aistudio.google.com/app/apikey
# Enables: linkedin_post_now, linkedin_weekly_plan, linkedin_rewrite_post, daily cron
GEMINI_API_KEY=your_gemini_api_key_here

# ── Daily Auto-Post Cron (optional) ────────────────────────────────────────
# Posts are always saved to the review queue — never published automatically
# Approve them via linkedin_list_queue before they go live
DAILY_POST_ENABLED=false
DAILY_POST_CRON=0 9 * * *
DAILY_POST_TOPICS=AI trends,productivity,leadership,startup lessons
DAILY_POST_VISIBILITY=PUBLIC

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
